# Middleware Server Settings
PORT=3000

# Tracksolid Open API Credentials (for signature verification & polling)
TRACKSOLID_USER_ID=your_tracksolid_user_id
TRACKSOLID_USER_PWD_MD5=your_tracksolid_user_pwd_md5_hash_lowercase
TRACKSOLID_APP_KEY=your_tracksolid_app_key
TRACKSOLID_APP_SECRET=your_tracksolid_app_secret
TRACKSOLID_IMEIS=comma_separated_imeis_to_poll_e.g_862798052972060
TRACKSOLID_POLL_INTERVAL=10000

# Target GPS Server Settings
GPS_SERVER_URL=http://gsh7.net/id39/api/api_loc.php
