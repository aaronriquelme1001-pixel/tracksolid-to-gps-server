# Middleware Server Settings
PORT=3000

# Tracksolid Open API Credentials (for signature verification)
# Set to your App Secret from Jimi/Tracksolid developer console
TRACKSOLID_APP_SECRET=your_tracksolid_app_secret_here

# Target GPS Server Settings
# Example: http://127.0.0.1/api/api_loc.php or http://your-gps-server.com
GPS_SERVER_URL=http://your-gps-server.com/api/api_loc.php
